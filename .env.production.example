DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=change-me

PUBLIC_SCHEME=https
SITE_DOMAIN=example.com
API_DOMAIN=api.example.com
NEXT_PUBLIC_API_BASE_URL=/api/v1

DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0,130.49.150.192,api.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=http://130.49.150.192,https://api.example.com
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://130.49.150.192,https://example.com,https://www.example.com

DJANGO_SERVE_MEDIA=false
DJANGO_USE_S3_MEDIA=true

POSTGRES_DB=econizhny
POSTGRES_USER=econizhny
POSTGRES_PASSWORD=change-me

WEB_PORT=80
API_BIND_PORT=18000
FRONTEND_BIND_PORT=13000
WEB_CONCURRENCY=3
APP_LOG_LEVEL=INFO
PIP_INDEX_URL=https://pypi.org/simple
PIP_EXTRA_INDEX_URL=
PIP_TRUSTED_HOST=
PIP_DEFAULT_TIMEOUT=120
PIP_RETRIES=15

BACKUP_TIMEZONE=Europe/Moscow
BACKUP_SCHEDULE_HOUR=3
BACKUP_SCHEDULE_MINUTE=0
BACKUP_RETENTION_DAYS=7
BACKUP_S3_PREFIX=ops
BACKUP_S3_BUCKET_NAME=
BACKUP_RUN_ON_START=false

AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_CUSTOM_DOMAIN=
AWS_S3_ADDRESSING_STYLE=path
AWS_S3_SIGNATURE_VERSION=s3v4
AWS_S3_VERIFY=/usr/lib/ssl/cert.pem
AWS_QUERYSTRING_AUTH=false
AWS_DEFAULT_ACL=
AWS_S3_OBJECT_ACL=public-read
AWS_LOCATION=
AWS_S3_REGION_NAME=
